# .kamal/secrets
# ─────────────────────────────────────────────────────────────
# Secrets are pulled from shell environment variables on YOUR
# LOCAL MACHINE when you run `kamal deploy`.
# DO NOT hardcode credentials here. This file IS committed to git.
#
# Before deploying, export these in your shell:
#
#   export KAMAL_REGISTRY_PASSWORD="your_docker_hub_password"
#   export DB_PASSWORD="a_strong_password_you_choose"
#
# RAILS_MASTER_KEY is read from config/master.key automatically.
# ─────────────────────────────────────────────────────────────

# Docker Hub password (used to push/pull the image)
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Rails master key (decrypts config/credentials.yml.enc)
RAILS_MASTER_KEY=$(cat config/master.key)

# PostgreSQL password (used by the database container)
POSTGRES_PASSWORD=$DB_PASSWORD

DATADOG_API_KEY=$DATADOG_API_KEY

DB_NAME=$DB_NAME

# URL-encode the password to prevent special characters (like @, :, or /) from breaking the connection URI
ENCODED_DB_PASSWORD=$(ruby -ruri -e 'print URI.encode_uri_component(ENV["DB_PASSWORD"] || "")')

# Database connection URL (used by the Rails application container)
DATABASE_URL="postgresql://visasponsoruk:${ENCODED_DB_PASSWORD}@visasponsoruk-postgres:5432/${ENCODED_DB_NAME}"


