# .kamal/secrets
# ─────────────────────────────────────────────────────────────
# Secrets are pulled from shell environment variables on YOUR
# LOCAL MACHINE when you run `kamal deploy`.
# DO NOT hardcode credentials here. This file IS committed to git.
#
# Before deploying, export these in your shell:
#
#   export KAMAL_REGISTRY_PASSWORD="your_docker_hub_password"
#   export DB_PASSWORD="a_strong_password_you_choose"
#   export DB_NAME="visasponsoruk_production"
#   export DATADOG_API_KEY="your_datadog_api_key"
#   export HTTP_USERNAME="your_pghero_dashboard_username"
#   export HTTP_PASSWORD="a_strong_password_you_choose"
#
# RAILS_MASTER_KEY is read from config/master.key automatically.
#
# NOTE: this file is parsed by the `dotenv` gem (via Kamal::Secrets), NOT
# executed as a bash script — only plain KEY=value lines and Kamal's $(...)
# inline command substitution work here. Bash constructs like `set -e` or
# `${VAR:?message}` are silently no-ops or get mangled, they do NOT abort
# the deploy. Required-variable validation lives in .kamal/hooks/pre-connect
# instead, which *is* a real executable script.
# ─────────────────────────────────────────────────────────────

# Docker Hub password (used to push/pull the image)
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Rails master key (decrypts config/credentials.yml.enc)
RAILS_MASTER_KEY=$(cat config/master.key)

# PostgreSQL password (used by the database container)
POSTGRES_PASSWORD=$DB_PASSWORD

DATADOG_API_KEY=$DATADOG_API_KEY

# HTTP Basic Auth credentials for the /pghero and /jobs dashboards
HTTP_USERNAME=$HTTP_USERNAME
HTTP_PASSWORD=$HTTP_PASSWORD

DB_NAME=$DB_NAME

# URL-encode the password/db name to prevent special characters (like @, :, or /) from breaking the connection URI
ENCODED_DB_PASSWORD=$(ruby -ruri -e 'print URI.encode_uri_component(ENV["DB_PASSWORD"] || "")')
ENCODED_DB_NAME=$(ruby -ruri -e 'print URI.encode_uri_component(ENV["DB_NAME"] || "")')

# Database connection URL (used by the Rails application container)
DATABASE_URL="postgresql://visasponsoruk:${ENCODED_DB_PASSWORD}@visasponsoruk-postgres:5432/${ENCODED_DB_NAME}"
