<%= turbo_frame_tag "search_results" do %>
  <% if @companies.any? %>
    <div class="space-y-4 max-w-2xl mx-auto">
      <p class="text-xs text-slate-500 mb-2 pl-1 font-semibold uppercase tracking-wider">
        Search Results (<%= @companies.size %> matches)
      </p>
      <% @companies.each do |company| %>
        <%= link_to company_path(company), data: { turbo_frame: "_top" }, class: "block group" do %>
          <div class="rounded-2xl border border-slate-900 bg-slate-900/20 p-5 hover:border-slate-800 hover:bg-slate-900/40 transition-all duration-200 shadow-sm hover:shadow-md">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <h3 class="text-lg font-bold text-white group-hover:text-indigo-400 transition-colors truncate">
                  <%= company.name %>
                </h3>

                <% if company.location.present? %>
                  <p class="text-xs text-slate-500 mt-1 flex items-center gap-1">
                    <svg class="h-3.5 w-3.5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <%= company.location %>
                  </p>
                <% end %>
              </div>

              <!-- Status Badge -->
              <div class="flex-shrink-0">
                <% if company.active_sponsor? %>
                  <span class="inline-flex items-center rounded-full bg-emerald-500/10 px-2.5 py-0.5 text-xs font-semibold text-emerald-400 border border-emerald-500/20">
                    Active Sponsor
                  </span>
                <% else %>
                  <span class="inline-flex items-center rounded-full bg-slate-900 px-2.5 py-0.5 text-xs font-semibold text-slate-500 border border-slate-800">
                    Removed
                  </span>
                <% end %>
              </div>
            </div>

            <!-- Licences / Routes badges -->
            <div class="mt-4 flex flex-wrap gap-1.5">
              <% company.sponsor_licences.each do |licence| %>
                <% if licence.active? %>
                  <span class="inline-flex items-center rounded-lg bg-slate-900 px-2.5 py-1 text-xs font-medium text-slate-400 border border-slate-850">
                    <span class="font-semibold text-slate-300 mr-1"><%= licence.route %></span>
                    <span class="text-[10px] text-slate-500">• Rating <%= licence.rating %></span>
                  </span>
                <% else %>
                  <span class="inline-flex items-center rounded-lg bg-slate-950 px-2.5 py-1 text-xs font-medium text-slate-600 border border-slate-900 line-through decoration-slate-800">
                    <span class="mr-1"><%= licence.route %></span>
                    <span class="text-[10px]">• Removed</span>
                  </span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% elsif @query.present? %>
    <div class="rounded-2xl border border-dashed border-slate-800 p-12 text-center bg-slate-900/10 backdrop-blur-sm max-w-2xl mx-auto">
      <svg class="mx-auto h-12 w-12 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="mt-4 text-sm font-semibold text-slate-350">No results found</h3>
      <p class="mt-1 text-xs text-slate-500">We couldn't find any licensed sponsor matching "<%= @query %>".</p>
    </div>
  <% end %>
<% end %>
