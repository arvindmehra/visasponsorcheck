<%= turbo_frame_tag "typeahead_results" do %>
  <% if companies.any? %>
    <div class="flex flex-col max-h-[380px] bg-white">
      <!-- Header / Info Bar -->
      <div class="px-5 py-2.5 text-[10px] font-bold text-slate-400 uppercase tracking-widest bg-slate-50/50 flex items-center justify-between border-b border-slate-100/60 select-none">
        <span>Suggestions</span>
        <span class="text-[9px] font-normal text-slate-400 lowercase normal-case tracking-normal flex items-center gap-1">
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15L12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
          </svg>
          Navigate with &uarr;&darr; keys
        </span>
      </div>

      <!-- Scrollable Suggestion List -->
      <div class="divide-y divide-slate-100/60 overflow-y-auto pr-0.5" role="listbox" id="typeahead-listbox" style="scrollbar-width: thin; scrollbar-color: #cbd5e1 transparent;">
        <% companies.each_with_index do |company, index| %>
          <%= link_to company_path(company), 
                      data: { 
                        turbo_frame: "_top", 
                        typeahead_option: true 
                      }, 
                      class: "group flex items-center justify-between px-5 py-3.5 text-sm hover:bg-indigo-50/40 transition-all duration-150 ease-in-out",
                      id: "typeahead-option-#{index}",
                      role: "option" do %>
            <div class="min-w-0 pr-4">
              <div class="font-bold text-slate-800 tracking-tight group-hover:text-indigo-600 transition-colors truncate">
                <%= company.name %>
              </div>
              <% if company.location.present? %>
                <div class="text-xs text-slate-500 font-medium truncate flex items-center gap-1.5 mt-1.5">
                  <svg class="h-3.5 w-3.5 text-slate-400 group-hover:text-indigo-400 transition-colors flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <%= company.location.strip.chomp(",") %>
                </div>
              <% end %>
            </div>

            <!-- Sponsor Status Badge with matching ring -->
            <div class="flex items-center gap-2 flex-shrink-0 select-none">
              <% if company.active_sponsor? %>
                <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-1 text-[10px] font-semibold text-emerald-700 border border-emerald-100 ring-1 ring-emerald-600/10">
                  Active
                </span>
              <% else %>
                <span class="inline-flex items-center rounded-full bg-slate-50 px-2.5 py-1 text-[10px] font-semibold text-slate-600 border border-slate-200/60 ring-1 ring-slate-600/10">
                  Removed
                </span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
      
      <!-- Footer Info and CTA -->
      <div class="bg-slate-50/50 px-5 py-3 border-t border-slate-100 flex justify-between items-center text-xs select-none">
        <span class="text-slate-400 font-medium">
          Showing <span class="font-semibold text-slate-600"><%= companies.size %></span> of <span class="font-semibold text-slate-600"><%= number_with_delimiter(companies.count) %></span> matches
        </span>
        <button type="button" 
                class="font-bold text-indigo-600 hover:text-indigo-700 inline-flex items-center gap-1 cursor-pointer transition-colors group/btn"
                data-action="click->search#enterPressed">
          <span>See all results</span>
          <svg class="h-3.5 w-3.5 transform group-hover/btn:translate-x-0.5 transition-transform duration-150" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </button>
      </div>
    </div>
  <% elsif query.present? %>
    <div class="py-10 px-5 text-center bg-white select-none">
      <svg class="mx-auto h-10 w-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div class="mt-3 text-sm font-semibold text-slate-700">No matches found</div>
      <div class="mt-1 text-xs text-slate-400">No registered sponsors match "<%= query %>"</div>
    </div>
  <% end %>
<% end %>
