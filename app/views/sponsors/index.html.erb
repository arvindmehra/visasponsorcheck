<% content_for :structured_data do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "UK Visa Sponsor Directory",
  "description": "Browse all licensed UK visa sponsors by city, visa route, and rating.",
  "url": "<%= sponsors_url %>",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "<%= root_url %>" },
      { "@type": "ListItem", "position": 2, "name": "Sponsors", "item": "<%= sponsors_url %>" }
    ]
  }
}
</script>
<% end %>

<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
  <!-- Breadcrumb -->
  <nav class="flex mb-8 text-xs text-slate-500 font-medium uppercase tracking-wider" aria-label="Breadcrumb">
    <%= link_to "Home", root_path, class: "hover:text-indigo-600 transition-colors" %>
    <span class="mx-2 text-slate-300">›</span>
    <span class="text-slate-800">Sponsors</span>
  </nav>

  <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 mb-3">UK Visa Sponsor Directory</h1>
  <p class="text-lg text-slate-500 mb-3 max-w-3xl">
    Browse <%= number_with_delimiter(@active_count) %> companies licensed by UKVI to sponsor UK work visas.
    Filter by city, visa route (Skilled Worker, Health &amp; Care, and more), or rating.
  </p>
  <p class="text-sm text-slate-400 mb-12 max-w-3xl">
    New to sponsorship? <%= link_to "Read our guide on how the UK visa sponsorship list works", sponsorship_list_guide_path, class: "text-indigo-600 hover:underline font-medium" %>.
  </p>

  <!-- Browse by City -->
  <section class="mb-14">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-slate-900">Browse by City</h2>
      <%= link_to locations_sponsors_path, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition-colors flex items-center gap-1" do %>
        <span>View All Locations (A-Z)</span>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      <% end %>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
      <% @cities.each do |city_slug| %>
        <% city_name = city_slug.split(" ").map(&:capitalize).join(" ") %>
        <%= link_to city_sponsors_path(city: city_slug),
              class: "rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-600 hover:shadow-sm transition-all duration-200 text-center" do %>
          <%= city_name %>
        <% end %>
      <% end %>
    </div>
  </section>

  <!-- Browse by Sector -->
  <section class="mb-14">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-slate-900">Browse by Sector</h2>
      <%= link_to sectors_sponsors_path, class: "text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition-colors flex items-center gap-1" do %>
        <span>View All Sectors</span>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      <% end %>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
      <% @top_sectors.each do |sector| %>
        <%= link_to sector_sponsors_path(sector: sector[:key]),
              class: "rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-600 hover:shadow-sm transition-all duration-200 flex items-center justify-between gap-3" do %>
          <span><%= sector[:name] %></span>
          <span class="shrink-0 inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-bold text-indigo-700 border border-indigo-150">
            <%= number_with_delimiter(sector[:count]) %>
          </span>
        <% end %>
      <% end %>
    </div>
  </section>

  <!-- Browse by Visa Route -->
  <section class="mb-14">
    <h2 class="text-2xl font-bold text-slate-900 mb-6">Browse by Visa Route</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
      <% @visa_routes.each do |route| %>
        <% route_slug = route.downcase.gsub(/\s+/, "-") %>
        <%= link_to visa_route_sponsors_path(route: route_slug),
              class: "rounded-xl border border-slate-200 bg-white px-5 py-4 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-600 hover:shadow-sm transition-all duration-200" do %>
          <%= route %>
        <% end %>
      <% end %>
    </div>
  </section>


</div>
