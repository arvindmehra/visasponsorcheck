<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <!-- Header Section -->
  <div class="rounded-3xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm mb-8 text-center md:text-left">
    <div class="max-w-3xl">
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight sm:text-4xl">
        Browse by Location
      </h1>
      <p class="mt-3 text-base text-slate-500 leading-relaxed">
        Find registered UK visa sponsors across <%= number_with_delimiter(@cities.size) %> cities, towns, and regions. 
        Select a location below to view active licensed companies.
      </p>
    </div>
  </div>

  <!-- A-Z Jump Bar and Search Filter Card -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-100/40 mb-8 space-y-6">
    <!-- Real-time Filter Search Input -->
    <div class="max-w-md">
      <label for="location-search" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Search Locations</label>
      <div class="relative">
        <input type="text" id="location-search" placeholder="Type to filter cities..." 
               class="block w-full rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:border-indigo-500 focus:bg-white focus:outline-none transition-all duration-200" />
        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
          <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Alphabet Quick-Jump Nav -->
    <div>
      <span class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Jump to Letter</span>
      <div class="flex flex-wrap gap-2 text-sm font-semibold">
        <% ('A'..'Z').each do |letter| %>
          <% has_cities = @grouped_cities.key?(letter) %>
          <% if has_cities %>
            <a href="#letter-<%= letter %>" class="letter-nav-btn h-9 w-9 inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-700 hover:border-indigo-400 hover:text-indigo-600 hover:bg-indigo-50/30 transition-all duration-150 shadow-sm">
              <%= letter %>
            </a>
          <% else %>
            <span class="h-9 w-9 inline-flex items-center justify-center rounded-lg border border-slate-100 bg-slate-50 text-slate-300 pointer-events-none">
              <%= letter %>
            </span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Locations A-Z List Section -->
  <div class="space-y-8" id="locations-container">
    <% @grouped_cities.each do |letter, cities_list| %>
      <div class="letter-group bg-white rounded-2xl border border-slate-200 p-6 md:p-8 shadow-sm shadow-slate-100/30 scroll-mt-6" id="letter-<%= letter %>">
        <div class="flex items-center gap-4 mb-6 border-b border-slate-100 pb-4">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 text-xl font-extrabold text-indigo-700 border border-indigo-150">
            <%= letter %>
          </span>
          <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">
            <%= pluralize(cities_list.size, "location") %>
          </span>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          <% cities_list.each do |city| %>
            <div class="city-item" data-name="<%= city[:name].downcase %>">
              <%= link_to city_sponsors_path(city: city[:slug]),
                    class: "block rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50/10 hover:shadow-sm transition-all duration-200 text-center truncate" do %>
                <%= city[:name] %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Empty State -->
    <div id="no-locations-message" class="hidden text-center py-16 rounded-2xl border border-dashed border-slate-350 bg-slate-50/50">
      <svg class="mx-auto h-10 w-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <h3 class="mt-4 text-sm font-bold text-slate-800">No matching locations found</h3>
      <p class="mt-1.5 text-xs text-slate-500">Try adjusting your search terms.</p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', function() {
    const searchInput = document.getElementById('location-search');
    if (!searchInput) return;

    searchInput.addEventListener('input', function(e) {
      const query = e.target.value.toLowerCase().trim();
      const letterGroups = document.querySelectorAll('.letter-group');
      const navButtons = document.querySelectorAll('.letter-nav-btn');
      let totalVisible = 0;

      letterGroups.forEach(group => {
        const letter = group.id.replace('letter-', '');
        const items = group.querySelectorAll('.city-item');
        let groupVisibleCount = 0;

        items.forEach(item => {
          const cityName = item.getAttribute('data-name');
          if (cityName.includes(query)) {
            item.style.display = 'block';
            groupVisibleCount++;
          } else {
            item.style.display = 'none';
          }
        });

        // Show/hide the entire letter block based on matches
        if (groupVisibleCount > 0) {
          group.style.display = 'block';
          totalVisible += groupVisibleCount;
        } else {
          group.style.display = 'none';
        }

        // Toggle nav button state
        const navBtn = Array.from(navButtons).find(btn => btn.innerText.trim() === letter);
        if (navBtn) {
          if (groupVisibleCount > 0) {
            navBtn.classList.remove('opacity-30', 'pointer-events-none');
          } else {
            navBtn.classList.add('opacity-30', 'pointer-events-none');
          }
        }
      });

      // Toggle overall empty state message
      const noResultsMsg = document.getElementById('no-locations-message');
      if (totalVisible === 0) {
        noResultsMsg.classList.remove('hidden');
      } else {
        noResultsMsg.classList.add('hidden');
      }
    });
  });
</script>
