<% content_for :structured_data do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "UK Visa Sponsors by Sector",
  "description": "Browse licensed UK visa sponsors grouped by industry sector.",
  "url": "<%= sectors_sponsors_url %>",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "<%= root_url %>" },
      { "@type": "ListItem", "position": 2, "name": "Sponsors", "item": "<%= sponsors_url %>" },
      { "@type": "ListItem", "position": 3, "name": "Sectors", "item": "<%= sectors_sponsors_url %>" }
    ]
  }
}
</script>
<% end %>

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <!-- Header Section -->
  <div class="rounded-3xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm mb-8 text-center md:text-left">
    <div class="max-w-3xl">
      <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight sm:text-4xl">
        Browse by Sector
      </h1>
      <p class="mt-3 text-base text-slate-500 leading-relaxed">
        Find registered UK visa sponsors by industry sector, based on their registered
        SIC (Standard Industrial Classification) code. Select a sector below to view
        active licensed companies.
      </p>
    </div>
  </div>

  <!-- Real-time Filter Search Input -->
  <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-100/40 mb-8">
    <div class="max-w-md">
      <label for="sector-search" class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">Search Sectors</label>
      <div class="relative">
        <input type="text" id="sector-search" placeholder="Type to filter sectors..."
               class="block w-full rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 text-sm text-slate-800 placeholder-slate-400 focus:border-indigo-500 focus:bg-white focus:outline-none transition-all duration-200" />
        <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
          <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <!-- Industries Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" id="sectors-container">
    <% @sectors.each do |sector| %>
      <div class="sector-item" data-name="<%= sector[:name].downcase %>">
        <% if sector[:count] > 0 %>
          <%= link_to sector_sponsors_path(sector: sector[:key]),
                class: "block h-full rounded-2xl border border-slate-200 bg-white p-5 hover:border-indigo-300 hover:shadow-sm transition-all duration-200" do %>
            <div class="flex items-start justify-between gap-3">
              <span class="font-semibold text-slate-800 hover:text-indigo-600 transition-colors"><%= sector[:name] %></span>
              <span class="shrink-0 inline-flex items-center rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs font-bold text-indigo-700 border border-indigo-150">
                <%= number_with_delimiter(sector[:count]) %>
              </span>
            </div>
          <% end %>
        <% else %>
          <div class="h-full rounded-2xl border border-dashed border-slate-200 bg-slate-50/40 p-5 opacity-60">
            <div class="flex items-start justify-between gap-3">
              <span class="font-semibold text-slate-500"><%= sector[:name] %></span>
              <span class="shrink-0 inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-bold text-slate-400 border border-slate-200">
                0
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Empty State -->
    <div id="no-sectors-message" class="hidden col-span-full text-center py-16 rounded-2xl border border-dashed border-slate-350 bg-slate-50/50">
      <svg class="mx-auto h-10 w-10 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <h3 class="mt-4 text-sm font-bold text-slate-800">No matching industries found</h3>
      <p class="mt-1.5 text-xs text-slate-500">Try adjusting your search terms.</p>
    </div>
  </div>

  <!-- Guide and Informational Section -->
  <div class="mt-16 border-t border-slate-200 pt-12">
    <div class="prose prose-slate max-w-none">
      <h2 class="text-xl font-bold text-slate-900 mb-4">UK Visa Sponsors by Industry Sector</h2>
      <p class="text-sm text-slate-500 leading-relaxed mb-4">
        Every company registered in the UK is classified under one or more <strong>Standard Industrial Classification (SIC) codes</strong>, which describe their main business activities. The Home Office register itself does not group companies by industry, making it challenging for job seekers to identify employers in their specific field.
      </p>
      <p class="text-sm text-slate-500 leading-relaxed">
        Our platform solves this by mapping the official register against registered SIC codes. This categorization allows you to browse sponsors across sectors like <strong>Information &amp; Communication (Software and Tech)</strong>, <strong>Human Health &amp; Social Work</strong>, <strong>Manufacturing</strong>, and more. This makes it easy to find and target companies in your domain that already have the legal authority to sponsor UK work visas.
      </p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', function() {
    const searchInput = document.getElementById('sector-search');
    if (!searchInput) return;

    searchInput.addEventListener('input', function(e) {
      const query = e.target.value.toLowerCase().trim();
      const items = document.querySelectorAll('.sector-item');
      let totalVisible = 0;

      items.forEach(item => {
        const name = item.getAttribute('data-name');
        if (name.includes(query)) {
          item.style.display = 'block';
          totalVisible++;
        } else {
          item.style.display = 'none';
        }
      });

      const noResultsMsg = document.getElementById('no-sectors-message');
      if (totalVisible === 0) {
        noResultsMsg.classList.remove('hidden');
      } else {
        noResultsMsg.classList.add('hidden');
      }
    });
  });
</script>
