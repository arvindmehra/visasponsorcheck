<!DOCTYPE html>
<html class="h-full bg-slate-50 text-slate-900 antialiased selection:bg-indigo-500 selection:text-white" lang="en">
  <head>
    <%= display_meta_tags(
          title: "UK Visa Sponsor Finder — Check Registered Companies",
          description: "Search and verify if any UK company is a licensed visa sponsor. View active licences, ratings, visa routes, and historical changes from the official GOV.UK register.",
          og: { image: image_url("logo.png") }
        ) %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="VisaSponsorUK">
    <meta name="mobile-web-app-capable" content="yes">

    <!-- Disable Turbo 8 prefetching (hover link preload) globally to prevent premature GET requests. -->
    <!-- To reactivate it, change content to "true" or remove the meta tag entirely. -->
    <meta name="turbo-prefetch" content="false">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Petrona:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

    <style>
      body {
        font-family: 'DM Sans', sans-serif;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Petrona', serif;
      }
    </style>

    <link rel="icon" href="<%= asset_path('favicon/favicon.ico') %>" type="image/x-icon">
    <link rel="icon" href="<%= asset_path('favicon/favicon.svg') %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= asset_path('favicon/apple-touch-icon.png') %>">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Google Consent Mode - must load BEFORE gtag -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        'ad_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied',
        'analytics_storage': 'denied'
      });
    </script>

    <% if Rails.env.production? %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= Rails.application.credentials.dig(:ga4, :measurement_id) %>"></script>
      <script>
        gtag('js', new Date());
        gtag('config', '<%= Rails.application.credentials.dig(:ga4, :measurement_id) %>', { send_page_view: false });
      </script>
    <% end %>

    <!-- Global Organisation + WebSite JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "VisaSponsorUK",
          "url": "<%= root_url %>",
          "logo": "<%= image_url('logo.png') %>",
          "description": "UK visa sponsor register tracker — search licensed sponsors from the official GOV.UK register.",
          "sameAs": []
        },
        {
          "@type": "WebSite",
          "name": "VisaSponsorUK",
          "url": "<%= root_url %>",
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "<%= search_url %>?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        }
      ]
    }
    </script>

    <!-- Per-page structured data (BreadcrumbList, FAQPage, ItemList etc.) -->
    <%= yield :structured_data %>
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body class="flex min-h-full flex-col bg-slate-50 text-slate-700">
    <!-- Premium navigation header -->
    <header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/80 backdrop-blur-md shadow-sm shadow-slate-100/50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <!-- Logo / Link to Home -->
          <div class="flex items-center flex-1">
            <a href="/" class="flex items-center gap-2.5 group" id="nav-logo-link">
              <%= image_tag 'logo-transparent.png', class: "h-10 w-auto flex-shrink-0 object-contain group-hover:scale-105 transition-all duration-300", alt: "VisaSponsorUK Logo" %>
            </a>
            <% unless current_page?(root_path) %>
              <div class="ml-6 flex-1 max-w-md hidden sm:block" data-controller="search">
                <%= form_with url: search_path, method: :get, 
                              class: "relative w-full", 
                              data: { 
                                search_target: "form", 
                                action: "submit->search#submit turbo:submit-end->search#finish" 
                              } do |f| %>
                  <div class="relative">
                    <!-- Input Field -->
                    <%= f.search_field :q, 
                                       placeholder: "Search company by name...", 
                                       class: "block w-full rounded-xl border border-slate-200 bg-slate-50/50 py-1.5 pl-4 pr-12 text-sm text-slate-950 placeholder-slate-400 focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all duration-200",
                                       data: { 
                                         search_target: "input",
                                         action: "input->search#perform keydown.down->search#navigateDown keydown.up->search#navigateUp keydown.esc->search#closeDropdown keydown.enter->search#enterPressed"
                                       },
                                       value: params[:q],
                                       autocomplete: "off",
                                       role: "combobox",
                                       aria: {
                                         expanded: "false",
                                         autocomplete: "list",
                                         controls: "typeahead-listbox"
                                       },
                                       id: "search-input-field-header" %>

                    <!-- Spinner / Loader -->
                    <div class="absolute inset-y-0 right-9 flex items-center pointer-events-none">
                      <svg class="animate-spin h-4 w-4 text-indigo-650 opacity-0 transition-opacity duration-200" 
                           data-search_target="spinner" 
                           fill="none" 
                           viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                      </svg>
                    </div>

                    <!-- Search Button -->
                    <button type="submit" class="absolute inset-y-0 right-0 flex items-center px-3 text-slate-400 hover:text-indigo-600 transition-colors" aria-label="Submit Search">
                      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
                      </svg>
                    </button>

                    <!-- Typeahead Dropdown -->
                    <div class="absolute left-0 right-0 z-50 mt-2 hidden rounded-xl border border-slate-100 bg-white/95 backdrop-blur-md shadow-xl max-h-[300px] overflow-hidden"
                         data-search-target="dropdown">
                      <%= turbo_frame_tag "typeahead_results" do %>
                        <!-- Suggestions will load here -->
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>

        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-1">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200 bg-white py-12 mt-auto shadow-sm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        
        <!-- Top Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-8 border-b border-slate-100">
          
          <!-- Column 1: Brand & Tagline -->
          <div class="md:col-span-1 space-y-4">
            <div class="flex items-center gap-2.5">
              <%= image_tag 'logo-transparent.png', class: "h-8 w-auto flex-shrink-0 object-contain", alt: "VisaSponsorUK Logo" %>
            </div>
            <p class="text-xs text-slate-500 leading-relaxed max-w-sm">
              Verify registered UK companies holding licensed visa sponsor status. Sourced regularly from the official GOV.UK sponsor logs.
            </p>
          </div>

          <!-- Column 2: Navigation Links -->
          <div class="space-y-3">
            <h4 class="text-xs font-semibold text-slate-800 uppercase tracking-wider">Navigation</h4>
            <ul class="space-y-2 text-xs">
              <li>
                <%= link_to "Browse Sponsors", sponsors_path, class: "text-slate-500 hover:text-indigo-600 transition-colors" %>
              </li>
              <li>
                <%= link_to "UK Visa Sponsorship List Guide", sponsorship_list_guide_path, class: "text-slate-500 hover:text-indigo-600 transition-colors" %>
              </li>
              <li>
                <%= link_to "Tier 2 / Skilled Worker Sponsors", visa_route_sponsors_path(route: "skilled-worker"), class: "text-slate-500 hover:text-indigo-600 transition-colors" %>
              </li>
              <li>
                <%= link_to "FAQ", faq_path, class: "text-slate-500 hover:text-indigo-600 transition-colors" %>
              </li>
            </ul>
          </div>

          <!-- Column 3: Data Sources -->
          <div class="space-y-3">
            <h4 class="text-xs font-semibold text-slate-800 uppercase tracking-wider">Official Data & Licensing</h4>
            <ul class="space-y-2 text-xs">
              <li>
                <a href="https://www.gov.uk/government/publications/register-of-licensed-sponsors-workers" target="_blank" rel="noopener noreferrer nofollow" class="text-slate-500 hover:text-indigo-600 transition-colors inline-flex items-center gap-1">
                  <span>GOV.UK Sponsors Register</span>
                  <svg class="h-3 w-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                </a>
              </li>
              <li>
                <a href="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/" target="_blank" rel="noopener noreferrer nofollow" class="text-slate-500 hover:text-indigo-600 transition-colors inline-flex items-center gap-1">
                  <span>Open Government Licence</span>
                  <svg class="h-3 w-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                </a>
              </li>
            </ul>
          </div>

        </div>

        <!-- Bottom Row -->
        <div class="pt-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <p class="text-[10px] text-slate-400 leading-relaxed max-w-2xl order-2 md:order-1">
            Disclaimer: VisaSponsorUK is an independent informational resource and is not affiliated, endorsed, or connected with the UK Home Office, UKVI, or any official government agency. All data is updated regularly from the official register but is provided as-is.
          </p>
          <p class="text-xs text-slate-500 shrink-0 order-1 md:order-2">
            &copy; <%= Time.current.year %> VisaSponsorUK. All rights reserved.
          </p>
        </div>

      </div>
    </footer>
    <!-- Cookie Consent Banner (Heidi Health inspired premium banner) -->
    <div data-controller="consent" class="fixed bottom-6 right-6 z-50 max-w-sm w-full bg-white/95 backdrop-blur-md rounded-2xl border border-slate-200 p-5 shadow-xl hidden" data-consent-target="banner">
      <h3 class="text-sm font-bold text-slate-900 mb-1.5">Cookie Preferences</h3>
      <p class="text-xs text-slate-500 mb-4 leading-relaxed">
        We use cookies to improve your experience, measure performance, and personalize advertisements. Learn more in our Privacy Policy.
      </p>
      <div class="flex gap-2.5">
        <button data-action="click->consent#acceptAll" class="flex-1 rounded-xl bg-indigo-600 px-3.5 py-2 text-xs font-semibold text-white hover:bg-indigo-700 transition-colors shadow-sm">
          Accept All
        </button>
        <button data-action="click->consent#declineAll" class="flex-1 rounded-xl border border-slate-200 bg-white px-3.5 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50 transition-colors">
          Decline
        </button>
      </div>
    </div>

  </body>
</html>
