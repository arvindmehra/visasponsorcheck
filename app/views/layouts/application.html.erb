<!DOCTYPE html>
<html class="h-full bg-slate-950 text-slate-100 antialiased selection:bg-indigo-500 selection:text-white">
  <head>
    <title><%= content_for(:title) || "UK Visa Sponsor Finder — Check Registered Companies" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:meta_description) || "Search and verify if any UK company is a licensed visa sponsor. View historical changes, license types, routes, and ratings directly from gov.uk registers." %>">
    
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="UK Visa Sponsor Finder">
    <meta name="mobile-web-app-capable" content="yes">
    
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Outfit', sans-serif;
      }
    </style>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex min-h-full flex-col bg-slate-950 text-slate-300">
    <!-- Premium navigation header -->
    <header class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur-md">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <!-- Logo / Link to Home -->
          <div class="flex items-center">
            <a href="/" class="flex items-center gap-2.5 group" id="nav-logo-link">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-tr from-indigo-500 to-violet-500 text-white shadow-md shadow-indigo-500/20 group-hover:scale-105 transition-all duration-300">
                <span class="font-extrabold text-lg leading-none select-none tracking-tighter">🇬🇧</span>
              </div>
              <div class="flex flex-col">
                <span class="font-bold text-white text-base tracking-tight leading-none group-hover:text-indigo-400 transition-colors">VisaSponsorCheck</span>
                <span class="text-[10px] text-slate-500 mt-0.5 tracking-wider uppercase font-semibold">UK Registry Tracker</span>
              </div>
            </a>
          </div>

          <!-- Quick Navigation / Stats badge -->
          <div class="flex items-center gap-4">
            <a href="https://www.gov.uk/government/publications/register-of-licensed-sponsors-workers" 
               target="_blank" 
               rel="noopener noreferrer" 
               class="hidden sm:inline-flex items-center gap-1.5 rounded-full bg-slate-900 px-3 py-1 text-xs font-medium text-slate-400 hover:text-white hover:bg-slate-850 border border-slate-850 hover:border-slate-700 transition-all duration-200"
               id="nav-gov-source-link">
              <span>Gov.uk Source</span>
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-1">
      <%= yield %>
    </main>

    <!-- Sleek Footer -->
    <footer class="border-t border-slate-900 bg-slate-950 py-10 mt-auto">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
          <div class="flex items-center gap-2.5">
            <div class="h-6 w-6 rounded bg-gradient-to-tr from-indigo-500 to-violet-500 flex items-center justify-center text-[10px] text-white font-black">V</div>
            <p class="text-xs text-slate-500">
              © <%= Time.current.year %> VisaSponsorCheck. Not affiliated with the UK government.
            </p>
          </div>
          <div class="flex gap-6 text-xs text-slate-500">
            <span class="inline-flex items-center gap-1.5">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
              Live updates direct from gov.uk registers
            </span>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
