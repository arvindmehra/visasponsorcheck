<!DOCTYPE html>
<html class="h-full bg-slate-50 text-slate-900 antialiased selection:bg-indigo-500 selection:text-white" lang="en">
  <head>
    <%= display_meta_tags(
          title: "UK Visa Sponsor Finder — Check Registered Companies",
          description: "Search and verify if any UK company is a licensed visa sponsor. View active licences, ratings, visa routes, and historical changes from the official GOV.UK register.",
          og: { image: image_url("logo.png") }
        ) %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="VisaSponsorUK">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
      body {
        font-family: 'Inter', sans-serif;
      }
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Outfit', sans-serif;
      }
    </style>

    <link rel="icon" href="<%= asset_path('favicon/favicon.ico') %>" type="image/x-icon">
    <link rel="icon" href="<%= asset_path('favicon/favicon.svg') %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= asset_path('favicon/apple-touch-icon.png') %>">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Google Consent Mode - must load BEFORE gtag -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        'ad_storage': 'denied',
        'ad_user_data': 'denied',
        'ad_personalization': 'denied',
        'analytics_storage': 'denied'
      });
    </script>

    <% if Rails.env.production? %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= Rails.application.credentials.dig(:ga4, :measurement_id) %>"></script>
      <script>
        gtag('js', new Date());
        gtag('config', '<%= Rails.application.credentials.dig(:ga4, :measurement_id) %>');
      </script>
    <% end %>

    <!-- Global Organisation + WebSite JSON-LD -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "VisaSponsorUK",
          "url": "<%= root_url %>",
          "logo": "<%= image_url('logo.png') %>",
          "description": "UK visa sponsor register tracker — search licensed sponsors from the official GOV.UK register.",
          "sameAs": []
        },
        {
          "@type": "WebSite",
          "name": "VisaSponsorUK",
          "url": "<%= root_url %>",
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "<%= search_url %>?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        }
      ]
    }
    </script>

    <!-- Per-page structured data (BreadcrumbList, FAQPage, ItemList etc.) -->
    <%= yield :structured_data %>
  </head>

  <body class="flex min-h-full flex-col bg-slate-50 text-slate-700">
    <!-- Premium navigation header -->
    <header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/80 backdrop-blur-md shadow-sm shadow-slate-100/50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <!-- Logo / Link to Home -->
          <div class="flex items-center">
            <a href="/" class="flex items-center gap-2.5 group" id="nav-logo-link">
              <%= image_tag 'logo-transparent.png', class: "h-10 w-auto flex-shrink-0 object-contain group-hover:scale-105 transition-all duration-300", alt: "VisaSponsorUK Logo" %>
            </a>
          </div>

        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-1">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="border-t border-slate-200 bg-white py-10 mt-auto shadow-inner shadow-slate-50/50">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
          <div class="flex items-center gap-3">
            <%= image_tag 'logo-transparent.png', class: "flex-shrink-0 object-contain", style: "height: 28px; width: auto;", alt: "VisaSponsorUK Logo" %>
            <p class="text-xs text-slate-500">
              © <%= Time.current.year %> VisaSponsorUK. All rights reserved.
            </p>
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-slate-400">
            <%= link_to "Browse Sponsors", sponsors_path, class: "hover:text-slate-600 transition-colors" %>
            <%= link_to "FAQ", faq_path, class: "hover:text-slate-600 transition-colors" %>
            <span>Data sourced from <a href="https://www.gov.uk/government/publications/register-of-licensed-sponsors-workers" target="_blank" rel="noopener noreferrer nofollow" class="underline hover:text-slate-600">GOV.UK</a> under the <a href="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/" target="_blank" rel="noopener noreferrer nofollow" class="underline hover:text-slate-600">Open Government Licence</a>.</span>
          </div>
        </div>
        <p class="mt-4 text-center text-xs text-slate-400">
          Not affiliated with the UK Home Office, UKVI, or any government body. Data is updated regularly from the official register.
        </p>
      </div>
    </footer>
  </body>
</html>
