<div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
  <!-- Hero Section -->
  <div class="text-center">
    <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-6xl">
      UK Visa Sponsor Registry
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-500">
      Search <%= number_with_delimiter(@active_companies_count) %> companies in the UK with a license to sponsor short-term and long-term work visas.
    </p>
    <% if @last_sync&.completed_at %>
      <p class="mt-3 text-xs text-slate-400">
        <svg class="inline h-3.5 w-3.5 mr-1 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" /></svg>
        Data updated <%= time_ago_in_words(@last_sync.completed_at) %> ago from the official GOV.UK register
      </p>
    <% end %>
  </div>

  <!-- Search Area (Stimulus Controller) -->
  <div class="mt-12" data-controller="search">
    <%= form_with url: search_path, method: :get, 
                  class: "relative mx-auto max-w-2xl", 
                  data: { 
                    search_target: "form", 
                    action: "submit->search#submit turbo:submit-end->search#finish" 
                  } do |f| %>
      <div class="relative">
        <!-- Input Field -->
        <%= f.search_field :q, 
                           placeholder: "Search company by name (e.g. Google, Nvidia)", 
                           class: "block w-full rounded-2xl border border-slate-200 bg-white py-4 pl-5 pr-16 text-base text-slate-950 placeholder-slate-400 shadow-lg focus:border-indigo-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all duration-300",
                           data: { 
                             search_target: "input",
                             action: "input->search#perform keydown.down->search#navigateDown keydown.up->search#navigateUp keydown.esc->search#closeDropdown keydown.enter->search#enterPressed"
                           },
                           autocomplete: "off",
                           role: "combobox",
                           aria: {
                             expanded: "false",
                             autocomplete: "list",
                             controls: "typeahead-listbox"
                           },
                           id: "search-input-field" %>

        <!-- Spinner / Loader -->
        <div class="absolute inset-y-0 right-12 flex items-center pointer-events-none">
          <svg class="animate-spin h-5 w-5 text-indigo-650 opacity-0 transition-opacity duration-200" 
               data-search_target="spinner" 
               fill="none" 
               viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>

        <!-- Search Button -->
        <button type="submit" class="absolute inset-y-0 right-0 flex items-center px-4 text-slate-400 hover:text-indigo-600 transition-colors" aria-label="Submit Search">
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
          </svg>
        </button>

        <!-- Typeahead Dropdown -->
        <div class="absolute left-0 right-0 z-50 mt-3 hidden rounded-2xl border border-slate-100 bg-white/95 backdrop-blur-md shadow-2xl shadow-slate-200/80 max-h-[380px] overflow-hidden"
             data-search-target="dropdown">
          <%= turbo_frame_tag "typeahead_results" do %>
            <!-- Suggestions will load here -->
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Results Frame -->
    <div class="mt-8">
      <%= turbo_frame_tag "search_results" do %>
        <!-- Default State / Search Prompts -->
        
      <% end %>
    </div>
  </div>

  <!-- Statistics Dashboard -->
  <div class="mt-20 border-t border-slate-200 pt-10">
    <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <!-- Active Licences -->
      <div class="flex flex-col gap-y-2 rounded-2xl bg-white border border-slate-200/60 p-6 shadow-sm shadow-slate-100/50">
        <dt class="text-xs font-semibold text-slate-550 uppercase tracking-wider">Active Licences</dt>
        <dd class="text-3xl font-bold tracking-tight text-slate-900">
          <%= number_with_delimiter(@active_licences_count) %>
        </dd>
      </div>

      <!-- Active Companies -->
      <div class="flex flex-col gap-y-2 rounded-2xl bg-white border border-slate-200/60 p-6 shadow-sm shadow-slate-100/50">
        <dt class="text-xs font-semibold text-slate-550 uppercase tracking-wider">Active Sponsors</dt>
        <dd class="text-3xl font-bold tracking-tight text-slate-900">
          <%= number_with_delimiter(@active_companies_count) %>
        </dd>
      </div>
    </dl>
  </div>

  <!-- Browse by City -->
  <% if @top_cities.any? %>
    <div class="mt-16">
      <h2 class="text-xl font-bold text-slate-900 mb-5">Browse Visa Sponsors by City</h2>
      <div class="flex flex-wrap gap-2">
        <% @top_cities.each do |city_slug| %>
          <% city_name = city_slug.split(" ").map(&:capitalize).join(" ") %>
          <%= link_to city_name, city_sponsors_path(city: city_slug),
                class: "rounded-full border border-slate-200 bg-white px-4 py-1.5 text-sm text-slate-600 hover:border-indigo-300 hover:text-indigo-600 transition-all duration-200 shadow-sm" %>
        <% end %>
        <%= link_to "View all locations (A-Z) →", locations_sponsors_path,
              class: "rounded-full border border-indigo-200 bg-indigo-50 px-4 py-1.5 text-sm text-indigo-600 hover:bg-indigo-100 transition-colors" %>
      </div>
    </div>
  <% end %>

  <!-- Browse by Visa Route -->
  <% if @visa_routes.any? %>
    <div class="mt-10">
      <h2 class="text-xl font-bold text-slate-900 mb-5">Browse by Visa Route</h2>
      <div class="flex flex-wrap gap-2">
        <% @visa_routes.each do |route| %>
          <% route_slug = route.downcase.gsub(/\s+/, "-") %>
          <%= link_to route, route_sponsors_path(route: route_slug),
                class: "rounded-full border border-slate-200 bg-white px-4 py-1.5 text-sm text-slate-600 hover:border-indigo-300 hover:text-indigo-600 transition-all duration-200 shadow-sm" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
