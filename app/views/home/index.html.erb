<div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
  <!-- Hero Section -->
  <div class="text-center">
    <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl bg-clip-text text-transparent bg-gradient-to-r from-white via-slate-100 to-slate-400">
      Find Licensed UK Visa Sponsors
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-400">
      Search the official government register of Worker and Temporary Worker sponsors. Real-time updates, status tracking, and licence history details.
    </p>
  </div>

  <!-- Search Area (Stimulus Controller) -->
  <div class="mt-12" data-controller="search">
    <%= form_with url: search_path, method: :get, 
                  class: "relative mx-auto max-w-2xl", 
                  data: { 
                    search_target: "form", 
                    action: "input->search#perform submit->search#submit turbo:submit-end->search#finish" 
                  } do |f| %>
      <div class="relative">
        <!-- Search Icon -->
        <div class="pointer-events-none absolute inset-y-0 left-4 flex items-center pr-3">
          <svg class="h-5 w-5 text-slate-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
          </svg>
        </div>

        <!-- Input Field -->
        <%= f.search_field :q, 
                           placeholder: "Search company by name (e.g. Google, Boltwhiz)...", 
                           class: "block w-full rounded-2xl border border-slate-800 bg-slate-900/60 py-4 pl-12 pr-12 text-base text-white placeholder-slate-500 shadow-xl backdrop-blur focus:border-indigo-500 focus:bg-slate-900 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition-all duration-300",
                           data: { search_target: "input" },
                           autocomplete: "off",
                           id: "search-input-field" %>

        <!-- Spinner / Loader -->
        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none">
          <svg class="animate-spin h-5 w-5 text-indigo-500 opacity-0 transition-opacity duration-200" 
               data-search_target="spinner" 
               fill="none" 
               viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </div>
      </div>
    <% end %>

    <!-- Results Frame -->
    <div class="mt-8">
      <%= turbo_frame_tag "search_results" do %>
        <!-- Default State / Search Prompts -->
        <div class="rounded-2xl border border-dashed border-slate-800 p-12 text-center bg-slate-900/10 backdrop-blur-sm">
          <svg class="mx-auto h-12 w-12 text-slate-650" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <h3 class="mt-4 text-sm font-semibold text-slate-350">No search query</h3>
          <p class="mt-1 text-xs text-slate-500">Type a company name above to begin searching live sponsors.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Statistics Dashboard -->
  <div class="mt-20 border-t border-slate-900 pt-10">
    <dl class="grid grid-cols-1 gap-6 sm:grid-cols-3">
      <!-- Active Licences -->
      <div class="flex flex-col gap-y-2 rounded-2xl bg-slate-900/30 border border-slate-900/80 p-6 backdrop-blur-sm">
        <dt class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Active Licences</dt>
        <dd class="text-3xl font-bold tracking-tight text-white">
          <%= number_with_delimiter(@active_licences_count) %>
        </dd>
      </div>

      <!-- Active Companies -->
      <div class="flex flex-col gap-y-2 rounded-2xl bg-slate-900/30 border border-slate-900/80 p-6 backdrop-blur-sm">
        <dt class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Active Sponsors</dt>
        <dd class="text-3xl font-bold tracking-tight text-white">
          <%= number_with_delimiter(@active_companies_count) %>
        </dd>
      </div>

      <!-- Sync Status -->
      <div class="flex flex-col gap-y-2 rounded-2xl bg-slate-900/30 border border-slate-900/80 p-6 backdrop-blur-sm">
        <dt class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Registry Sync</dt>
        <dd class="text-sm font-semibold text-slate-400 mt-2 flex items-center gap-1.5">
          <% if @last_sync %>
            <span class="h-2.5 w-2.5 rounded-full bg-emerald-500 inline-block shadow shadow-emerald-500/50"></span>
            <span>Synced <%= time_ago_in_words(@last_sync.completed_at || @last_sync.created_at) %> ago</span>
          <% else %>
            <span class="h-2.5 w-2.5 rounded-full bg-amber-500 inline-block"></span>
            <span>Sync pending</span>
          <% end %>
        </dd>
      </div>
    </dl>
  </div>
</div>
