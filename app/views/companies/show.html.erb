<% content_for :title, "#{@company.name} — UK Visa Sponsor Status" %>
<% content_for :meta_description, "Verify if #{@company.name} is a licensed UK visa sponsor. See active routes, sponsor rating, location: #{@company.location || 'Unknown'}, and historical record updates." %>

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
  <!-- Breadcrumb navigation -->
  <nav class="flex mb-8" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3 text-xs text-slate-500 font-medium uppercase tracking-wider">
      <li class="inline-flex items-center">
        <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
      </li>
      <li>
        <div class="flex items-center">
          <svg class="h-3 w-3 text-slate-400 mx-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
          <span class="text-slate-550">Sponsor Registry</span>
        </div>
      </li>
      <li aria-current="page">
        <div class="flex items-center">
          <svg class="h-3 w-3 text-slate-400 mx-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
          <span class="text-slate-800 truncate"><%= @company.name %></span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- Company Header -->
  <div class="rounded-3xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm mb-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight sm:text-4xl leading-tight">
            <%= @company.name %>
          </h1>
          <!-- Active Status Badge -->
          <div>
            <% if @company.active_sponsor? %>
              <span class="inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 border border-emerald-250 shadow-sm shadow-emerald-500/10">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 mr-1.5 animate-pulse"></span>
                Active Sponsor
              </span>
            <% else %>
              <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 border border-slate-200">
                Removed from Register
              </span>
            <% end %>
          </div>
        </div>

        <% if @company.location.present? %>
          <p class="text-sm text-slate-550 mt-2.5 flex items-center gap-1.5">
            <svg class="h-4.5 w-4.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-slate-700"><%= @company.location %></span>
          </p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Page Grid layout -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column: Licence details (2/3 width) -->
    <div class="lg:col-span-2 space-y-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm shadow-slate-100/40">
        <h2 class="text-xl font-bold text-slate-900 mb-6">Registered Visa Licences</h2>

        <div class="overflow-hidden">
          <table class="min-w-full divide-y divide-slate-200">
            <thead>
              <tr class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                <th scope="col" class="pb-4">Route</th>
                <th scope="col" class="pb-4">Type</th>
                <th scope="col" class="pb-4">Rating</th>
                <th scope="col" class="pb-4 text-right">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-150 text-sm">
              <% @sponsor_licences.each do |licence| %>
                <tr class="group hover:bg-slate-50/50 transition-colors">
                  <td class="py-4 pr-3 font-semibold text-slate-900">
                    <%= licence.route %>
                  </td>
                  <td class="py-4 px-3 text-slate-600">
                    <%= licence.licence_type %>
                  </td>
                  <td class="py-4 px-3">
                    <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-indigo-50 text-xs font-bold border border-indigo-150 text-indigo-700">
                      <%= licence.rating %>
                    </span>
                  </td>
                  <td class="py-4 pl-3 text-right">
                    <% if licence.active? %>
                      <span class="inline-flex items-center text-xs font-semibold text-emerald-600">
                        Active
                      </span>
                    <% else %>
                      <span class="inline-flex items-center text-xs font-medium text-slate-400 line-through">
                        Removed
                      </span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Historical Record metadata card -->
      <% if false %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @sponsor_licences.each do |licence| %>
          <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm shadow-slate-100/30">
            <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-3 truncate">
              Metadata — <%= licence.route %>
            </h3>
            <div class="space-y-2 text-xs">
              <div class="flex justify-between">
                <span class="text-slate-500">First recorded:</span>
                <span class="text-slate-800 font-medium"><%= licence.first_seen_at.strftime("%B %d, %Y") %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-500">Last verified:</span>
                <span class="text-slate-800 font-medium"><%= licence.last_seen_at.strftime("%B %d, %Y") %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-slate-500">CSV Raw Name:</span>
                <span class="text-slate-700 font-mono italic truncate max-w-[200px]" title="<%= licence.organisation_name %>">
                  "<%= licence.organisation_name %>"
                </span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      <% end %>
    </div>

    <!-- Right Column: History Timeline (1/3 width) -->
    <% if false %>
      <div class="space-y-6">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-100/40">
          <h2 class="text-xl font-bold text-slate-900 mb-6">Activity History</h2>

          <% if @change_events.any? %>
            <div class="flow-root">
              <ul role="list" class="-mb-8">
                <% @change_events.each_with_index do |event, index| %>
                  <li>
                    <div class="relative pb-8">
                      <!-- Line connecting icons -->
                      <% if index < @change_events.size - 1 %>
                        <span class="absolute top-4 left-4 -ml-px h-full w-0.5 bg-slate-150" aria-hidden="true"></span>
                      <% end %>

                      <div class="relative flex space-x-3">
                        <!-- Event Icon -->
                        <div>
                          <span class="flex h-8 w-8 items-center justify-center rounded-full bg-slate-50 border border-slate-200 text-sm shadow-sm">
                            <%= event.icon %>
                          </span>
                        </div>

                        <!-- Event Content -->
                        <div class="flex-1 min-w-0 pt-1.5">
                          <p class="text-sm font-semibold text-slate-850">
                            <%= event.human_description %>
                          </p>
                          <div class="flex justify-between items-center mt-1 text-xs text-slate-500">
                            <span>Import Run #<%= event.sponsor_import_log_id %></span>
                            <time datetime="<%= event.occurred_at.iso8601 %>">
                              <%= time_ago_in_words(event.occurred_at) %> ago
                            </time>
                          </div>
                        </div>
                      </div>
                    </div>
                  </li>
                <% end %>
              </ul>
            </div>
          <% else %>
            <div class="text-center py-6">
              <p class="text-xs text-slate-500">No activity history recorded yet.</p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
