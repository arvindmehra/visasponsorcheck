<% # Meta tags are set in CompaniesController#show via set_meta_tags %>
<% content_for :structured_data do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": "<%= @company.name.gsub('"', '\"') %>",
      "url": "<%= company_url(@company) %>",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "<%= @company.town %>",
        "addressCountry": "GB"
      },
      "description": "<%= company_summary_paragraph(@company, @sponsor_licences).gsub('"', '\\"') %>"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "<%= root_url %>" },
        { "@type": "ListItem", "position": 2, "name": "Sponsors", "item": "<%= sponsors_url %>" },
        <% if @company.city_slug.present? %>
        { "@type": "ListItem", "position": 3, "name": "<%= @company.location %>", "item": "<%= city_sponsors_url(city: @company.city_slug) %>" },
        { "@type": "ListItem", "position": 4, "name": "<%= @company.name.gsub('"', '\"') %>", "item": "<%= company_url(@company) %>" }
        <% else %>
        { "@type": "ListItem", "position": 3, "name": "<%= @company.name.gsub('"', '\"') %>", "item": "<%= company_url(@company) %>" }
        <% end %>
      ]
    }
  ]
}
</script>
<% end %>

<% if Rails.env.production? %>
  <script>
    gtag('event', 'sponsor_check', {
      company_name: '<%= j @company.name %>',
      result: '<%= @company.active_sponsor? ? "active" : "removed" %>'
    });
  </script>
<% end %>

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">

  <!-- Breadcrumb navigation -->
  <nav class="flex mb-8" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3 text-xs text-slate-500 font-medium uppercase tracking-wider">
      <li class="inline-flex items-center">
        <%= link_to "Home", root_path, class: "hover:text-indigo-600 transition-colors" %>
      </li>
      <li>
        <div class="flex items-center">
          <svg class="h-3 w-3 text-slate-400 mx-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
          <%= link_to "Sponsors", sponsors_path, class: "hover:text-indigo-600 transition-colors" %>
        </div>
      </li>
      <% if @company.city_slug.present? %>
        <li>
          <div class="flex items-center">
            <svg class="h-3 w-3 text-slate-400 mx-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
            <%= link_to @company.location, city_sponsors_path(city: @company.city_slug), class: "hover:text-indigo-600 transition-colors" %>
          </div>
        </li>
      <% end %>
      <li aria-current="page">
        <div class="flex items-center">
          <svg class="h-3 w-3 text-slate-400 mx-1" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
          <span class="text-slate-800 truncate"><%= @company.name %></span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- Company Header -->
  <div class="rounded-3xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm mb-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight sm:text-4xl leading-tight">
            <%= @company.name %>
          </h1>
          <!-- Active Status Badge -->
          <div>
            <% if @company.active_sponsor? %>
              <span class="inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700 border border-emerald-250 shadow-sm shadow-emerald-500/10">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 mr-1.5 animate-pulse"></span>
                Active Sponsor
              </span>
            <% else %>
              <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 border border-slate-200">
                Removed from Register
              </span>
            <% end %>
          </div>
        </div>

        <% if @company.location.present? %>
          <p class="text-sm text-slate-550 mt-2.5 flex items-center gap-1.5">
            <svg class="h-4.5 w-4.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <% if @company.city_slug.present? %>
              <%= link_to @company.location, city_sponsors_path(city: @company.city_slug), class: "text-indigo-600 hover:underline font-medium" %>
            <% else %>
              <span class="text-slate-700"><%= @company.location %></span>
            <% end %>
          </p>
        <% end %>
        
      </div>
    </div>
  </div>

  <!-- Page Grid layout -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column: Licence details (2/3 width) -->
    <div class="lg:col-span-2 space-y-6">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm shadow-slate-100/40">
        <h2 class="text-xl font-bold text-slate-900 mb-6">Company Summary</h2>

        <p class="text-sm text-slate-600 mb-4 leading-relaxed">
          <%= company_licence_summary_paragraph(@company, @sponsor_licences) %>
        </p>

        <% company_expanded_profile_paragraphs(@company, @sponsor_licences).each do |paragraph| %>
          <p class="text-sm text-slate-600 mb-4 leading-relaxed">
            <%= paragraph %>
          </p>
        <% end %>

        <% if @company.enriched_at.present? %>
          <%= render partial: 'companies/profile_summary', locals: { company: @company } %>
        <% else %>
          <%= turbo_frame_tag "company_profile_summary_#{@company.id}", src: enrich_company_path(@company, card: :profile_summary), loading: :lazy %>
        <% end %>

        <div class="overflow-hidden">
          <table class="min-w-full divide-y divide-slate-200">
            <thead>
              <tr class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                <th scope="col" class="pb-4">Route</th>
                <th scope="col" class="pb-4">Type</th>
                <th scope="col" class="pb-4">Rating</th>
                <th scope="col" class="pb-4 text-right">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-150 text-sm">
              <% @sponsor_licences.each do |licence| %>
                <tr class="group hover:bg-slate-50/50 transition-colors">
                  <td class="py-4 pr-3 font-semibold text-slate-900">
                    <%= licence.route %>
                  </td>
                  <td class="py-4 px-3 text-slate-600">
                    <%= licence.licence_type %>
                  </td>
                  <td class="py-4 px-3">
                    <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-indigo-50 text-xs font-bold border border-indigo-150 text-indigo-700">
                      <%= licence.rating %>
                    </span>
                  </td>
                  <td class="py-4 pl-3 text-right">
                    <%= sponsor_status_badge(licence.active?) %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>

        <!-- External Resources Section -->
        <% if @company.enriched_at.present? %>
          <%= render partial: 'companies/external_resources_card', locals: { company: @company } %>
        <% else %>
          <%= turbo_frame_tag "company_external_#{@company.id}", src: enrich_company_path(@company, card: :external), loading: :lazy do %>
            <div class="mt-8 pt-6 border-t border-slate-150 animate-pulse">
              <h3 class="h-4 bg-slate-200 rounded-md w-1/4 mb-3"></h3>
              <div class="flex flex-wrap gap-4">
                <div class="h-4 bg-slate-200 rounded w-24"></div>
                <div class="h-4 bg-slate-200 rounded w-20"></div>
                <div class="h-4 bg-slate-200 rounded w-28"></div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Right Column: Quick Links & History Timeline (1/3 width) -->
    <div class="space-y-6">
      <% if @company.enriched_at.present? && @company.company_profile.present? %>
        <%= render partial: 'companies/details_card', locals: { company: @company } %>
      <% else %>
        <%= turbo_frame_tag "company_details_#{@company.id}", src: enrich_company_path(@company, card: :details), loading: :lazy do %>
          <!-- Company Details Loading Skeleton -->
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm shadow-slate-100/40 mb-6 animate-pulse">
            <h2 class="h-5 bg-slate-200 rounded-md w-1/3 mb-4"></h2>
            <div class="space-y-4">
              <div>
                <span class="h-3 bg-slate-150 rounded w-1/4 block"></span>
                <p class="h-4 bg-slate-200 rounded w-3/4 mt-2 block"></p>
                <p class="h-4 bg-slate-200 rounded w-1/2 mt-1 block"></p>
              </div>
              <div>
                <span class="h-3 bg-slate-150 rounded w-1/4 block"></span>
                <p class="h-4 bg-slate-200 rounded w-1/3 mt-2 block"></p>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

      <%= render partial: "companies/related_sponsors", locals: { related_companies: @related_companies } %>
    </div>
  </div>
</div>
